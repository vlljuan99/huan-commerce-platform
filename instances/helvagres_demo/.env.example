# instances/helvagres_demo/.env.example
# Copiar a .env y rellenar con valores reales.
# NUNCA subir el fichero .env a git.

# ── Seguridad ─────────────────────────────────────────────────────────────────
SECRET_KEY=cambia-esto-por-una-clave-segura
DEBUG=True

# ── Base de datos (dejar en blanco para usar SQLite por defecto) ──────────────
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# ── Email ─────────────────────────────────────────────────────────────────────
# EMAIL_HOST=smtp.ejemplo.es
# EMAIL_PORT=587
# EMAIL_HOST_USER=info@helvagres.es
# EMAIL_HOST_PASSWORD=contraseña
# EMAIL_USE_TLS=True

# ── Almacenamiento (dejar en blanco para ficheros locales) ────────────────────
# AWS_STORAGE_BUCKET_NAME=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
